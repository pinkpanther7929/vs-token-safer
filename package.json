{
  "name": "vs-token-safer-dev",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Dev tooling (lint/format/test) for the vs-token-safer marketplace. Not published; the publishable package lives in server/ (npm: vs-token-safer).",
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "eval": "node eval/run.mjs",
    "eval:steer": "node eval/test-edit-steer.mjs",
    "eval:skillopt": "node eval/skillopt/selftest.mjs",
    "test": "npm run eval && npm run eval:steer && npm run eval:skillopt",
    "bench": "node benchmarks/run.mjs",
    "bench:rank": "node eval/rank-bench.mjs",
    "bump": "node scripts/bump.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "prettier": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
